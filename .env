# ──────────────────────────────────────────────
# Google Gemini API
# ──────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_OPENAI_API_KEY

# Gemini model to use (options: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-exp)
GEMINI_MODEL=YOUR_OPENAI_MODEL
# ──────────────────────────────────────────────
# Google Cloud Translation API (replaces Azure Translator)
# ──────────────────────────────────────────────
# Option A: Use your GEMINI_API_KEY above — the preprocessing.py
#           uses Gemini itself for translation (no extra key needed).
#
# Option B: If you prefer the dedicated Google Cloud Translation API,
#           set your service-account JSON path here (leave blank to use Gemini):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ──────────────────────────────────────────────
# Backend URL (used by Streamlit chat_ui.py)
# ──────────────────────────────────────────────
BACKEND_URL=http://127.0.0.1:8075
